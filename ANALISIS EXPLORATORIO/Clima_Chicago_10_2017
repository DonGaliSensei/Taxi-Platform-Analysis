import requests
import pandas as pd
from bs4 import BeautifulSoup
#se obtiene el contenido del URL
URL = 'https://practicum-content.s3.us-west-1.amazonaws.com/data-analyst-eng/moved_chicago_weather_2017.html'

#se hace la solicitud del URL
response = requests.get(URL)

#condicion de solicitud del URL
print('Condicion de solicitud del URL: ', response)

#se analiza el contenido del URL con BeautifulSoup
soup = BeautifulSoup(response.text, 'html.parser')
table = soup.find('table', attrs={"id": "weather_records"})

#se obtiene el encabezado de la tabla
headers = []
for th in table.find_all('th'):
    headers.append(th.text.strip())
#se obtiene el contenido de la tabla
rows = []
for tr in table.find_all('tr')[1:]:
    cells = tr.find_all('td')
    row = [cell.text.strip() for cell in cells]
    rows.append(row)
#se crea un DataFrame con el contenido de la tabla
df = pd.DataFrame(rows, columns=headers)
#se muestra el DataFrame
print(df)

